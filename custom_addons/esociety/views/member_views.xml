<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_society_member_tree" model="ir.ui.view">
        <field name="name">esociety.member.tree</field>
        <field name="model">esociety.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="partner_id"/>
                <!-- <field name="name"/>
                <field name="email"/>
                <field name="phone"/> -->
                <field name="flat_id"/>
                <field name="flat_number"/>
                <field name="join_date"/>
                <field name="is_owner"/>
            </list>
        </field>
    </record>

    <record id="view_society_member_form" model="ir.ui.view">
        <field name="name">esociety.member.form</field>
        <field name="model">esociety.member</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="%(account.action_move_out_invoice_type)d"
                            string="Invoices"
                            type="action"
                            context="{'search_default_partner_id': partner_id, 'default_partner_id': partner_id}"
                            class="oe_stat_button"/>
                </header>
                <sheet>
                    <group>
                        <field name="partner_id" options="{'no_create': True}"/>
                        <field name="flat_id"/>
                        <field name="flat_number" readonly="1"/>
                        <field name="join_date"/>
                        <field name="is_owner"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_society_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">esociety.member</field>
        <field name="view_mode">list,form</field>
        <field name="view_id" ref="view_society_member_tree"/>
    </record>
    

    <!-- <menuitem id="menu_society_management_root" name="Society Management"/> -->
    <menuitem id="menu_society_member" name="Members" parent="menu_esociety_master" action="action_society_member" sequence="2"/>
</odoo>
